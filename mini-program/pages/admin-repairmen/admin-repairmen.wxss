.container { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.page-title { font-size: 36rpx; font-weight: bold; }
.add-btn { background: #1890ff; color: #fff; border: none; border-radius: 10rpx; font-size: 26rpx; padding: 0 30rpx; height: 64rpx; line-height: 64rpx; }
.loading, .empty { text-align: center; color: #999; padding: 60rpx 0; font-size: 28rpx; }
.repairman-item { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; display: flex; justify-content: space-between; align-items: center; }
.repairman-info { flex: 1; }
.repairman-name { display: block; font-size: 30rpx; font-weight: bold; color: #333; }
.repairman-username { display: block; font-size: 24rpx; color: #888; margin: 4rpx 0; }
.repairman-phone { display: block; font-size: 24rpx; color: #888; }
.repairman-actions { display: flex; flex-direction: column; gap: 10rpx; margin-left: 16rpx; }
.edit-btn { background: #1890ff; color: #fff; border: none; border-radius: 8rpx; font-size: 24rpx; padding: 0 16rpx; height: 56rpx; line-height: 56rpx; }
.delete-btn { background: #ff4d4f; color: #fff; border: none; border-radius: 8rpx; font-size: 24rpx; padding: 0 16rpx; height: 56rpx; line-height: 56rpx; }
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 100; }
.modal { background: #fff; border-radius: 20rpx; padding: 40rpx; margin: 40rpx; width: 80%; }
.modal-title { display: block; font-size: 34rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx; }
.form-input { width: 100%; height: 80rpx; border: 2rpx solid #e8e8e8; border-radius: 8rpx; padding: 0 20rpx; font-size: 28rpx; margin-bottom: 16rpx; box-sizing: border-box; }
.modal-btns { display: flex; gap: 20rpx; margin-top: 10rpx; }
.cancel-btn { flex: 1; background: #f0f0f0; color: #333; border: none; border-radius: 12rpx; }
.submit-btn { flex: 1; background: #1890ff; color: #fff; border: none; border-radius: 12rpx; }
