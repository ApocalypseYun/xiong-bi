.repairman-container {
  min-height: 100vh;
  background: #f5f7fa;
}

/* 标签页 */
.tab-bar {
  display: flex;
  background: white;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-item.active {
  color: #667eea;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #667eea;
  border-radius: 2rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 500;
}

.tab-badge {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  background: #fc8181;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 订单列表 */
.order-list {
  height: calc(100vh - 100rpx);
  padding: 20rpx;
}

.order-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-type {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3748;
}

.order-time {
  font-size: 24rpx;
  color: #a0aec0;
}

.order-body {
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.info-text {
  font-size: 26rpx;
  color: #4a5568;
}

.description {
  background: #f7fafc;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
}

.desc-text {
  font-size: 26rpx;
  color: #4a5568;
  line-height: 1.6;
}

.order-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid #e2e8f0;
  text-align: center;
}

/* 按钮 */
.accept-btn, .complete-btn, .evaluate-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 12rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 600;
}

.accept-btn {
  background: #4299e1;
  color: white;
}

.complete-btn {
  background: #48bb78;
  color: white;
}

.evaluate-btn {
  background: #f5a623;
  color: white;
}

.evaluated-text {
  font-size: 26rpx;
  color: #48bb78;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #a0aec0;
}
