/* Repairman Homepage Styles - Warm Minimalist */

.container {
  min-height: 100vh;
  background: #faf8f5;
  padding-bottom: 40rpx;
}

/* User Header */
.user-header {
  background: linear-gradient(135deg, #6b4c3d 0%, #8b6f5c 100%);
  padding: 60rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(107, 76, 61, 0.25);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #d4a574 0%, #c9956b 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.avatar-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: 600;
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.user-role {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.logout-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 16rpx 28rpx;
  border-radius: 30rpx;
  backdrop-filter: blur(10rpx);
}

.logout-icon {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* Stats Section */
.stats-section {
  margin: 0 30rpx 30rpx;
}

.stats-card {
  background: linear-gradient(135deg, #6b4c3d 0%, #8b6f5c 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(107, 76, 61, 0.2);
  position: relative;
}

.stats-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.stats-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.stats-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stats-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.stats-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.stats-arrow {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  font-size: 40rpx;
  color: #fff;
}

.stats-badge {
  position: absolute;
  top: -10rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.stats-row {
  display: flex;
  gap: 16rpx;
}

.stats-card-small {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(107, 76, 61, 0.08);
}

.stats-icon-sm {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.stats-icon-sm.pending { background: #fff3e0; }
.stats-icon-sm.processing { background: #e3f2fd; }
.stats-icon-sm.completed { background: #e8f5e9; }
.stats-icon-sm.evaluation { background: #fff8e1; }

.stats-num-sm {
  font-size: 36rpx;
  font-weight: 700;
  color: #6b4c3d;
}

.stats-label-sm {
  font-size: 22rpx;
  color: #8b7355;
}

/* Section Common Styles */
.section {
  margin: 0 30rpx 30rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(107, 76, 61, 0.08);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #4a4035;
}

.title-icon {
  font-size: 36rpx;
}

/* Announcement Carousel */
.announcement-carousel {
  position: relative;
}

.swiper {
  height: 160rpx;
}

.announcement-item {
  background: linear-gradient(135deg, #f5f0eb 0%, #ebe4dc 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  border: 1rpx solid rgba(139, 115, 85, 0.1);
}

.announcement-badge {
  align-self: flex-start;
  background: linear-gradient(135deg, #d4a574 0%, #c9956b 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.announcement-title {
  font-size: 30rpx;
  color: #4a4035;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.announcement-date {
  font-size: 22rpx;
  color: #8b7355;
}

.swiper-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.dot {
  width: 16rpx;
  height: 8rpx;
  background: #ddd5cc;
  border-radius: 4rpx;
  transition: all 0.3s;
}

.dot.active {
  width: 32rpx;
  background: #d4a574;
}

/* Action Grid */
.action-grid {
  display: flex;
  gap: 20rpx;
}

.action-item {
  flex: 1;
  background: #faf8f5;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: all 0.3s;
  border: 1rpx solid rgba(139, 115, 85, 0.08);
  position: relative;
}

.action-item.primary {
  background: linear-gradient(135deg, #6b4c3d 0%, #8b6f5c 100%);
  border: none;
}

.action-item:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(139, 115, 85, 0.15);
}

.action-item.primary .action-icon {
  background: rgba(255, 255, 255, 0.2);
  box-shadow: none;
}

.action-item.primary .action-name {
  color: #fff;
}

.action-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a4035;
}

.action-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #fff;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}

/* Order List */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-item {
  background: #faf8f5;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid rgba(139, 115, 85, 0.08);
}

.order-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a4035;
}

.order-room {
  font-size: 24rpx;
  color: #8b7355;
}

.order-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.order-status.processing {
  font-size: 24rpx;
  color: #fa8c16;
  background: #fff7e6;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.order-arrow {
  font-size: 32rpx;
  color: #8b7355;
}

/* Tips Section */
.tips-section {
  margin: 0 30rpx;
}

.tips-card {
  background: linear-gradient(135deg, #f8f4f0 0%, #f0ebe5 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  border-left: 6rpx solid #d4a574;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #4a4035;
  margin-bottom: 16rpx;
}

.tips-content {
  display: block;
  font-size: 26rpx;
  color: #6b5d4d;
  line-height: 1.6;
}
