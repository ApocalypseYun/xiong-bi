.container { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.page-title { font-size: 36rpx; font-weight: bold; margin-bottom: 20rpx; text-align: center; }
.section-title { font-size: 30rpx; font-weight: bold; margin: 20rpx 0 10rpx; color: #333; }
.empty { text-align: center; color: #999; padding: 30rpx 0; font-size: 28rpx; }
.order-card { background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; }
.repair-type { display: block; font-size: 32rpx; font-weight: bold; margin-bottom: 8rpx; }
.order-location { display: block; font-size: 26rpx; color: #555; margin-bottom: 6rpx; }
.order-desc { display: block; font-size: 26rpx; color: #777; margin-bottom: 6rpx; }
.order-user { display: block; font-size: 24rpx; color: #999; margin-bottom: 16rpx; }
.order-status.completed { display: block; color: #52c41a; font-size: 26rpx; margin-bottom: 10rpx; }
.complete-btn { background: #52c41a; color: #fff; border: none; border-radius: 12rpx; margin-top: 10rpx; }
.eval-btn { background: #1890ff; color: #fff; border: none; border-radius: 12rpx; margin-top: 10rpx; }
.eval-done { display: block; color: #999; font-size: 24rpx; margin-top: 10rpx; }
.eval-wait { display: block; color: #aaa; font-size: 24rpx; margin-top: 10rpx; font-style: italic; }
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 100; }
.modal { background: #fff; border-radius: 20rpx; padding: 40rpx; margin: 40rpx; width: 80%; }
.modal-title { display: block; font-size: 34rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx; }
.modal-label { display: block; font-size: 26rpx; color: #666; margin-bottom: 10rpx; }
.eval-textarea { width: 100%; height: 160rpx; border: 2rpx solid #e8e8e8; border-radius: 8rpx; padding: 16rpx; font-size: 26rpx; margin: 20rpx 0; box-sizing: border-box; }
.modal-btns { display: flex; gap: 20rpx; margin-top: 20rpx; }
.cancel-btn { flex: 1; background: #f0f0f0; color: #333; border: none; border-radius: 12rpx; }
.submit-btn { flex: 1; background: #1890ff; color: #fff; border: none; border-radius: 12rpx; }
