.container { padding: 30rpx; background: #f5f5f5; min-height: 100vh; }
.page-title { font-size: 36rpx; font-weight: bold; margin-bottom: 20rpx; text-align: center; }
.loading, .empty { text-align: center; color: #999; padding: 60rpx 0; font-size: 28rpx; }
.order-card { background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; }
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.repair-type { font-size: 32rpx; font-weight: bold; }
.urged-badge { background: #ff4d4f; color: #fff; font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 20rpx; }
.order-location { display: block; font-size: 26rpx; color: #333; margin-bottom: 8rpx; }
.order-desc { display: block; font-size: 26rpx; color: #555; margin-bottom: 8rpx; }
.order-user, .order-contact, .order-time { display: block; font-size: 24rpx; color: #888; margin-bottom: 6rpx; }
.image-list { display: flex; flex-wrap: wrap; gap: 10rpx; margin: 16rpx 0; }
.order-img { width: 160rpx; height: 160rpx; border-radius: 8rpx; }
.accept-btn { background: #1890ff; color: #fff; border: none; border-radius: 12rpx; margin-top: 16rpx; }
