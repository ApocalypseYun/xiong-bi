<view class="register-container">
  <view class="header">
    <view class="back-btn" bindtap="goBack"><text>←</text></view>
    <view class="header-title">注册账号</view>
  </view>

  <view class="register-card">
    <view class="role-section">
      <view class="section-title">选择角色</view>
      <view class="role-tabs">
        <view class="role-tab {{role === 'student' ? 'active' : ''}}" bindtap="switchRole" data-role="student">
          <text class="role-tab-icon">👨‍🎓</text>
          <text>学生</text>
        </view>
        <view class="role-tab {{role === 'admin' ? 'active' : ''}}" bindtap="switchRole" data-role="admin">
          <text class="role-tab-icon">👨‍💼</text>
          <text>管理员</text>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="input-group">
        <text class="input-label">学号<text class="required">*</text></text>
        <view class="input-wrapper {{errors.username ? 'error' : ''}}">
          <text class="input-icon">🎓</text>
          <input
            class="input-field"
            placeholder="请输入学号（需与住户表匹配）"
            value="{{username}}"
            data-field="username"
            bindinput="onInput"
          />
        </view>
        <text class="error-tip" wx:if="{{errors.username}}">{{errors.username}}</text>
      </view>

      <view class="input-group">
        <text class="input-label">密码<text class="required">*</text></text>
        <view class="input-wrapper {{errors.password ? 'error' : ''}}">
          <text class="input-icon">🔒</text>
          <input 
            class="input-field" 
            placeholder="至少6位密码" 
            password="{{!showPassword}}"
            value="{{password}}"
            data-field="password"
            bindinput="onInput"
          />
          <view class="password-toggle" bindtap="togglePassword" data-field="showPassword">
            <text>{{showPassword ? '🙈' : '👁️'}}</text>
          </view>
        </view>
        <text class="error-tip" wx:if="{{errors.password}}">{{errors.password}}</text>
      </view>

      <view class="input-group">
        <text class="input-label">确认密码<text class="required">*</text></text>
        <view class="input-wrapper {{errors.confirmPassword ? 'error' : ''}}">
          <text class="input-icon">🔐</text>
          <input 
            class="input-field" 
            placeholder="再次输入密码" 
            password="{{!showConfirmPassword}}"
            value="{{confirmPassword}}"
            data-field="confirmPassword"
            bindinput="onInput"
          />
          <view class="password-toggle" bindtap="togglePassword" data-field="showConfirmPassword">
            <text>{{showConfirmPassword ? '🙈' : '👁️'}}</text>
          </view>
        </view>
        <text class="error-tip" wx:if="{{errors.confirmPassword}}">{{errors.confirmPassword}}</text>
      </view>

      <block wx:if="{{role === 'student'}}">
        <view class="input-group">
          <text class="input-label">真实姓名<text class="required">*</text></text>
          <view class="input-wrapper {{errors.realName ? 'error' : ''}}">
            <text class="input-icon">✏️</text>
            <input
              class="input-field"
              placeholder="请输入真实姓名（需与住户表匹配）"
              value="{{realName}}"
              data-field="realName"
              bindinput="onInput"
            />
          </view>
          <text class="error-tip" wx:if="{{errors.realName}}">{{errors.realName}}</text>
        </view>

        <view class="input-group">
          <text class="input-label">手机号<text class="required">*</text></text>
          <view class="input-wrapper {{errors.phone ? 'error' : ''}}">
            <text class="input-icon">📱</text>
            <input 
              class="input-field" 
              placeholder="请输入手机号" 
              type="number"
              maxlength="11"
              value="{{phone}}"
              data-field="phone"
              bindinput="onInput"
            />
          </view>
          <text class="error-tip" wx:if="{{errors.phone}}">{{errors.phone}}</text>
        </view>

        <view class="form-row">
          <view class="input-group">
            <text class="input-label">楼栋<text class="required">*</text></text>
            <view class="input-wrapper {{errors.building ? 'error' : ''}}">
              <text class="input-icon">🏢</text>
              <input 
                class="input-field" 
                placeholder="如:A栋" 
                value="{{building}}"
                data-field="building"
                bindinput="onInput"
              />
            </view>
            <text class="error-tip" wx:if="{{errors.building}}">{{errors.building}}</text>
          </view>

          <view class="input-group">
            <text class="input-label">房间号<text class="required">*</text></text>
            <view class="input-wrapper {{errors.roomNumber ? 'error' : ''}}">
              <text class="input-icon">🚪</text>
              <input 
                class="input-field" 
                placeholder="如:101" 
                value="{{roomNumber}}"
                data-field="roomNumber"
                bindinput="onInput"
              />
            </view>
            <text class="error-tip" wx:if="{{errors.roomNumber}}">{{errors.roomNumber}}</text>
          </view>
        </view>
      </block>
    </view>

    <view class="forgot-password-section">
      <text class="forgot-link" bindtap="goToForgotPassword">忘记密码？</text>
    </view>

    <button class="register-btn" bindtap="handleRegister" disabled="{{isLoading}}">

    <view class="bottom-tip">
      <text class="tip-text">已有账号？<text class="tip-link" bindtap="goBack">立即登录</text></text>
    </view>
  </view>
</view>
