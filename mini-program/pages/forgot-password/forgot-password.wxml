<!--forgot-password.wxml-->
<view class="container">
  <view class="page-header">
    <text class="page-title">重置密码</text>
    <text class="page-subtitle">请填写注册时的个人信息进行验证</text>
  </view>

  <view class="form-card">
    <view class="input-group">
      <text class="input-label">学号</text>
      <view class="input-wrapper {{errors.username ? 'error' : ''}}">
        <input class="input-field" placeholder="请输入学号" value="{{username}}"
          bindinput="onInput" data-field="username" />
      </view>
      <text class="error-tip" wx:if="{{errors.username}}">{{errors.username}}</text>
    </view>

    <view class="input-group">
      <text class="input-label">姓名</text>
      <view class="input-wrapper {{errors.realName ? 'error' : ''}}">
        <input class="input-field" placeholder="请输入姓名" value="{{realName}}"
          bindinput="onInput" data-field="realName" />
      </view>
      <text class="error-tip" wx:if="{{errors.realName}}">{{errors.realName}}</text>
    </view>

    <view class="input-group">
      <text class="input-label">手机号</text>
      <view class="input-wrapper {{errors.phone ? 'error' : ''}}">
        <input class="input-field" type="number" placeholder="请输入手机号" value="{{phone}}"
          bindinput="onInput" data-field="phone" />
      </view>
      <text class="error-tip" wx:if="{{errors.phone}}">{{errors.phone}}</text>
    </view>

    <view class="input-group">
      <text class="input-label">栋数</text>
      <view class="input-wrapper {{errors.building ? 'error' : ''}}">
        <input class="input-field" placeholder="如：A栋" value="{{building}}"
          bindinput="onInput" data-field="building" />
      </view>
      <text class="error-tip" wx:if="{{errors.building}}">{{errors.building}}</text>
    </view>

    <view class="input-group">
      <text class="input-label">寝室号</text>
      <view class="input-wrapper {{errors.roomNumber ? 'error' : ''}}">
        <input class="input-field" placeholder="如：101" value="{{roomNumber}}"
          bindinput="onInput" data-field="roomNumber" />
      </view>
      <text class="error-tip" wx:if="{{errors.roomNumber}}">{{errors.roomNumber}}</text>
    </view>

    <view class="input-group">
      <text class="input-label">QQ邮箱</text>
      <view class="input-wrapper {{errors.qqEmail ? 'error' : ''}}">
        <input class="input-field" type="email" placeholder="请输入QQ邮箱" value="{{qqEmail}}"
          bindinput="onInput" data-field="qqEmail" />
      </view>
      <text class="error-tip" wx:if="{{errors.qqEmail}}">{{errors.qqEmail}}</text>
    </view>

    <view class="input-group">
      <text class="input-label">新密码</text>
      <view class="input-wrapper {{errors.newPassword ? 'error' : ''}}">
        <input class="input-field" password="true" placeholder="请输入新密码（至少6位）"
          value="{{newPassword}}" bindinput="onInput" data-field="newPassword" />
      </view>
      <text class="error-tip" wx:if="{{errors.newPassword}}">{{errors.newPassword}}</text>
    </view>

    <view class="input-group">
      <text class="input-label">确认新密码</text>
      <view class="input-wrapper {{errors.confirmPassword ? 'error' : ''}}">
        <input class="input-field" password="true" placeholder="请再次输入新密码"
          value="{{confirmPassword}}" bindinput="onInput" data-field="confirmPassword" />
      </view>
      <text class="error-tip" wx:if="{{errors.confirmPassword}}">{{errors.confirmPassword}}</text>
    </view>

    <button class="reset-btn {{isLoading ? 'loading' : ''}}" bindtap="handleReset" disabled="{{isLoading}}">
      {{isLoading ? '重置中...' : '重置密码'}}
    </button>

    <view class="back-link" bindtap="goBack">
      <text>返回登录</text>
    </view>
  </view>
</view>
